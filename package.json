{
  "name": "knowbase",
  "version": "1.3.0",
  "description": "本地 Windows 桌面博客/日程记录软件",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/launch.js dev",
    "build": "electron-vite build",
    "start": "node scripts/launch.js start",
    "preview": "electron-vite preview",
    "pack": "electron-vite build && electron-builder --win --publish=never"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "iconv-lite": "^0.7.2",
    "lucide-react": "^1.0.0",
    "markdown-it": "^14.2.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sql.js": "^1.12.0",
    "trash": "^10.1.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.2.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.local.knowbase",
    "productName": "Knowbase",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.png",
      "uninstallerIcon": "build/icon.png"
    }
  }
}
