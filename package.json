{
  "name": "knowbase",
  "version": "1.7.0",
  "description": "Knowbase Programmer Edition — 本地 Windows 桌面知识管理工具",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/launch.js dev",
    "build": "electron-vite build",
    "start": "node scripts/launch.js start",
    "preview": "electron-vite preview",
    "pack": "electron-vite build && electron-builder --win --publish=never"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "highlight.js": "^11.11.1",
    "iconv-lite": "^0.7.2",
    "lucide-react": "^1.0.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.12.0",
    "trash": "^10.1.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.2.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.local.knowbase.programmer",
    "productName": "Knowbase Programmer Edition",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
