{
  "name": "knowledge-recorder",
  "version": "1.0.0",
  "description": "本地 Windows 桌面博客/日程记录软件",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/launch.js dev",
    "build": "electron-vite build",
    "start": "node scripts/launch.js start",
    "preview": "electron-vite preview",
    "pack": "electron-vite build && electron-builder --win --publish=never"
  },
  "dependencies": {
    "lucide-react": "^1.0.0",
    "marked": "^18.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.2.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.local.knowledge-recorder",
    "productName": "KnowledgeRecorder",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.ico"
    }
  }
}
